# LfrGit per-user config. Copy to lfr-git.local.conf and set your team's fork.
# lfr-git.local.conf is gitignored, so your team setting stays local.

# Your team's fork org on GitHub. lfrGitSync / lfrGitSyncEE sync upstream into it.
LFR_GIT_FORK_ORG="your-team-fork-org"

# Upstream org to sync from (default: liferay).
LFR_GIT_UPSTREAM_ORG="liferay"

# Master mirror branches for lfrGitUpdateMaster to keep current, as
# "branch:remote" pairs. Each is updated from <remote>/master and created (local
# + on your fork) if it does not exist. Defaults to ("master:upstream").
LFR_GIT_MASTER_MIRRORS=("master:upstream" "masterBrian:brian")
